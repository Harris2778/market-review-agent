# === 必填：LLM 驱动 ===
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === 必填：智能体 API 密钥（平台调用你时用的鉴权） ===
AGENT_API_KEY=your-agent-api-key-here

# === 推荐：金融数据 API（不配也可以用，配了数据更精准） ===
# Tushare Pro — A股行情/31行业/资金流向（200元/年，https://tushare.pro）
TUSHARE_TOKEN=your_tushare_token

# Finnhub — 全球指数（免费，https://finnhub.io）
FINNHUB_API_KEY=your_finnhub_key

# FRED — 美国宏观数据（免费，https://fred.stlouisfed.org）
FRED_API_KEY=your_fred_key

# === 可选：新闻搜索增强 ===
# Brave Search API（免费 2000次/月，https://brave.com/search/api/）
BRAVE_SEARCH_API_KEY=your_brave_key
